---
import Layout from "@/layouts/main.astro";
import Header from "@/components/Header.astro";
import Button from "@/components/Button.astro";
---

<Layout>
  <div class="wrap flex max-w-3xl flex-col gap-2">
    <h1 class="text-6xl font-bold">SanghaPunk.</h1>
    <h2 class="text-4xl">
      Uma comunidade budista revolucionária para o século 21, com um toque de Brasil.
    </h2>
    <p>
      Para ter uma introdução filosófica ao budismo, sem
      <em>business</em> e <em>papo de coach</em>:
    </p>
    <!-- <Button> é um placeholder.
         Talvez usar um card com uma imagem ilustrativa .
    -->
    <Button class="min-h-16 w-80">Guia SanghaPunk</Button>
    <p>Conheça nosso manifesto.</p>
    <Button class="min-h-16 w-80">Manifesto</Button>
  </div>
</Layout>
