---
import Layout from "@/layouts/main.astro";
import ImageCard from "@/components/ImageCard.astro";

import Guia from "@/assets/guia.jpg";
import Manifesto from "@/assets/manifesto-crop.jpg";
---

<Layout>
  <div class="wrap flex max-w-3xl flex-col gap-2">
    <h1 class="text-6xl font-bold">SanghaPunk.</h1>
    <h2 class="text-4xl">
      Uma comunidade budista revolucionária para o século 21, com um toque de Brasil.
    </h2>
    <div class="flex gap-4">
      <ImageCard
        title="Guia SanghaPunk"
        description="Uma introdução filosófica ao budismo, sem <em>business</em> e <em>papo de coach</em>."
        imageSrc={Guia}
        href="/guia"
      />
      <ImageCard
        title="Manifesto"
        description="O que é a SanghaPunk? Conheça."
        imageSrc={Manifesto}
        href="/manifesto"
      />
    </div>
  </div>
</Layout>
