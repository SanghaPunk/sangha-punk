---
const { href, style } = Astro.props;
const isSelected = Astro.url.pathname === href || (href !== "/" && Astro.url.pathname.includes(href));
---

<li class={`${isSelected && "not-first:border-b-2 not-first:border-primary"}`}>
  <a href={href} class={`${style} ${!isSelected && "hover:text-muted-foreground"} flex items-center gap-2 w-full`}>
    <slot />
  </a>
</li>
